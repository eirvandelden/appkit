<link rel="manifest" href="<%= manifest_path %>">
<meta name="theme-color" content="#f5f9fa" media="(prefers-color-scheme: light)">
<meta name="theme-color" content="#012b38" media="(prefers-color-scheme: dark)">
<link rel="apple-touch-icon" href="<%= apple_touch_icon_path %>">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="appkit-vapid-public-key" content="<%= Rails.application.credentials.dig(:web_push, :vapid_public_key) %>">
